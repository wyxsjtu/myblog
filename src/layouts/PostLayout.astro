---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TagList from '../components/TagList.astro';
import Sidebar from '../components/sidebar/Sidebar.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  category?: string;
  tags?: string[];
  cover?: string;
  headings?: Heading[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  cover,
  headings = [],
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={cover}
  type="article"
  publishDate={pubDate}
  withSidebar={true}
>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      {description && <p class="post-description muted">{description}</p>}
      <div class="post-meta">
        {category && (
          <a
            href={`/posts/category/${encodeURIComponent(category.toLowerCase())}/`}
            class:list={['post-category', `cat-${category}`]}
          >{category}</a>
        )}
        <FormattedDate
          date={pubDate}
          showUpdated={!!updatedDate}
          updated={updatedDate}
        />
        {tags.length > 0 && <span class="dot">·</span>}
        <TagList tags={tags} />
      </div>
      {cover && <img src={cover} alt={title} class="post-cover" loading="eager" />}
    </header>

    <div class="post-content">
      <slot />
    </div>

    <footer class="post-footer">
      <a href="/posts/" class="back-link">← 返回文章列表</a>
    </footer>
  </article>

  <Sidebar slot="sidebar" headings={headings} />
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .post-title {
    font-size: 2rem;
    margin: 0 0 0.5rem;
    line-height: 1.25;
    letter-spacing: -0.02em;
  }
  .post-description {
    font-size: 1.05rem;
    margin: 0.5rem 0 1rem;
  }
  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--text-subtle);
    font-size: 0.9rem;
  }
  .dot { color: var(--text-subtle); }
  .post-category {
    display: inline-flex;
    align-items: center;
    padding: 0.1rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: 4px;
    border: 1px solid currentColor;
    line-height: 1.5;
    text-decoration: none;
    transition: opacity var(--transition);
  }
  .post-category:hover { opacity: 0.8; text-decoration: none; }
  .cat-技术 {
    color: #2563eb;
    background: rgb(37 99 235 / 0.10);
  }
  :global(:root[data-theme='dark']) .cat-技术 {
    color: #60a5fa;
    background: rgb(96 165 250 / 0.14);
  }
  .cat-生活 {
    color: #db2777;
    background: rgb(219 39 119 / 0.10);
  }
  :global(:root[data-theme='dark']) .cat-生活 {
    color: #f472b6;
    background: rgb(244 114 182 / 0.14);
  }
  .cat-思考 {
    color: #d97706;
    background: rgb(217 119 6 / 0.10);
  }
  :global(:root[data-theme='dark']) .cat-思考 {
    color: #fbbf24;
    background: rgb(251 191 36 / 0.14);
  }
  .post-cover {
    width: 100%;
    margin-top: 1.5rem;
    border-radius: var(--radius);
  }
  .post-content :global(h2) { margin-top: 2.5rem; scroll-margin-top: 80px; }
  .post-content :global(h3) { scroll-margin-top: 80px; }
  .post-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .back-link {
    color: var(--text-muted);
    text-decoration: none;
  }
  .back-link:hover {
    color: var(--accent);
    text-decoration: none;
  }
  @media (max-width: 600px) {
    .post-title { font-size: 1.65rem; }
  }
</style>
