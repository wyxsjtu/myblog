---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE } from '../consts';
import { getAllPosts } from '../utils/posts';

const posts = (await getAllPosts()).slice(0, 5);
---

<BaseLayout>
  <section class="hero">
    <h1 class="hero-title">{SITE.title}</h1>
    <p class="hero-desc muted">{SITE.description}</p>
    <div class="hero-links">
      {SITE.social.github && (
        <a href={SITE.social.github} target="_blank" rel="noopener">GitHub</a>
      )}
      {SITE.social.email && (
        <a href={`mailto:${SITE.social.email}`}>Email</a>
      )}
      {SITE.social.twitter && (
        <a href={SITE.social.twitter} target="_blank" rel="noopener">Twitter</a>
      )}
      <a href="/rss.xml">RSS</a>
    </div>
  </section>

  <section class="recent">
    <div class="recent-header">
      <h2>最新文章</h2>
      <a href="/posts/" class="view-all">查看全部 →</a>
    </div>
    {posts.length === 0 ? (
      <p class="muted">暂时还没有文章。</p>
    ) : (
      <div class="post-list">
        {posts.map((post) => (
          <PostCard
            href={`/posts/${post.id}/`}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 2rem 0 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1rem;
  }
  .hero-title {
    font-size: 2.25rem;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .hero-desc {
    margin: 0 0 1rem;
    font-size: 1.05rem;
  }
  .hero-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.95rem;
  }
  .recent-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin: 2rem 0 0.5rem;
  }
  .recent-header h2 {
    margin: 0;
    font-size: 1.25rem;
  }
  .view-all {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
</style>
