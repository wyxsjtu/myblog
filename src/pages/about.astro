---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';
---

<BaseLayout title="关于" description={`关于 ${SITE.author}`}>
  <h1>关于</h1>

  <p>你好，我是 <strong>{SITE.author}</strong>。</p>

  <p>
    这是我的个人博客，记录技术学习、项目思考、以及偶尔的生活感悟。
    站点使用 <a href="https://astro.build/">Astro</a> 构建，
    托管在 <a href="https://pages.cloudflare.com/">Cloudflare Pages</a>。
  </p>

  <h2>联系我</h2>
  <ul>
    {SITE.social.email && <li>Email: <a href={`mailto:${SITE.social.email}`}>{SITE.social.email}</a></li>}
    {SITE.social.github && <li>GitHub: <a href={SITE.social.github}>{SITE.social.github}</a></li>}
    {SITE.social.twitter && <li>Twitter: <a href={SITE.social.twitter}>{SITE.social.twitter}</a></li>}
  </ul>

  <h2>关于本站</h2>
  <ul>
    <li>所有文章使用 Markdown 写作，源码在 GitHub 公开</li>
    <li>支持深色模式，跟随系统设置或手动切换</li>
    <li>提供 <a href="/rss.xml">RSS 订阅</a></li>
  </ul>
</BaseLayout>
