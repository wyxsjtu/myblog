---
import SidebarCard from './SidebarCard.astro';
import { SITE } from '../../consts';
import { getAllPosts, getAllTags } from '../../utils/posts';

const [posts, tags] = await Promise.all([getAllPosts(), getAllTags()]);
const launch = new Date(SITE.launchDate);
const now = new Date();
const days = Math.max(
  1,
  Math.floor((now.getTime() - launch.getTime()) / (1000 * 60 * 60 * 24)),
);
const useBusuanzi = SITE.sidebar.busuanzi;
---

<SidebarCard title="站点">
  <ul class="stats">
    <li>
      <span class="label muted">文章</span>
      <span class="value">{posts.length}</span>
    </li>
    <li>
      <span class="label muted">标签</span>
      <span class="value">{tags.size}</span>
    </li>
    <li>
      <span class="label muted">运行</span>
      <span class="value">{days} <span class="unit">天</span></span>
    </li>
    {useBusuanzi && (
      <>
        <li>
          <span class="label muted">访问</span>
          <span class="value"><span id="busuanzi_value_site_uv">·</span> <span class="unit">人</span></span>
        </li>
        <li>
          <span class="label muted">浏览</span>
          <span class="value"><span id="busuanzi_value_site_pv">·</span> <span class="unit">次</span></span>
        </li>
      </>
    )}
  </ul>
</SidebarCard>

{useBusuanzi && (
  <script
    is:inline
    async
    src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"
  ></script>
)}

<style>
  .stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem 0.75rem;
  }
  .stats li {
    display: flex;
    flex-direction: column;
    padding: 0.35rem 0;
  }
  .label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .value {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    margin-top: 0.1rem;
  }
  .unit {
    font-size: 0.7rem;
    color: var(--text-subtle);
    font-weight: 400;
    margin-left: 0.1rem;
  }
</style>
