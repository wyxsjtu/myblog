---
import SidebarCard from './SidebarCard.astro';
import { getAllTags, slugifyTag } from '../../utils/posts';

const tagMap = await getAllTags();
const tags = [...tagMap.entries()]
  .map(([name, posts]) => ({ name, count: posts.length }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 8);
---

{tags.length > 0 && (
  <SidebarCard title="热门标签">
    <div class="tag-cloud">
      {tags.map((t) => (
        <a href={`/tags/${slugifyTag(t.name)}/`} class="tag-pill">
          <span class="tag-name">#{t.name}</span>
          <span class="tag-count">{t.count}</span>
        </a>
      ))}
    </div>
  </SidebarCard>
)}

<style>
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    border: 1px solid var(--border-subtle);
    background: var(--bg);
    color: var(--text-muted);
    font-size: 0.8rem;
    text-decoration: none;
    transition: color var(--transition), border-color var(--transition);
  }
  .tag-pill:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }
  .tag-count {
    color: var(--text-subtle);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }
</style>
