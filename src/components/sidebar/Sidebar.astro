---
import { SITE } from '../../consts';
import ProfileCard from './ProfileCard.astro';
import RecentPosts from './RecentPosts.astro';
import PopularTags from './PopularTags.astro';
import SiteStats from './SiteStats.astro';
import TableOfContents from './TableOfContents.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  // 当存在 headings 时，会优先在文章页显示 TOC
  headings?: Heading[];
}

const { headings } = Astro.props;
const showToc = !!(headings && headings.length > 0);
const cfg = SITE.sidebar;
---

<aside class="sidebar" aria-label="侧边栏">
  <div class="sidebar-stack">
    {cfg.profile && <ProfileCard />}
    {showToc && <TableOfContents headings={headings!} />}
    {!showToc && cfg.recentPosts && <RecentPosts />}
    {cfg.popularTags && <PopularTags />}
    {cfg.stats && <SiteStats />}
  </div>
</aside>

<style>
  .sidebar {
    /* sticky 让侧边栏跟随滚动一段距离后保持可见 */
    position: sticky;
    top: 80px;
    align-self: start;
    /* 防止内容超过视口高度时无法滚动 */
    max-height: calc(100vh - 90px);
    overflow-y: auto;
    /* 隐藏滚动条但保留滚动 */
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
    padding-right: 4px;
  }
  .sidebar::-webkit-scrollbar { width: 6px; }
  .sidebar::-webkit-scrollbar-track { background: transparent; }
  .sidebar::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 3px;
  }
  .sidebar-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 1024px) {
    .sidebar {
      position: static;
      max-height: none;
      overflow: visible;
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }
  }
</style>
