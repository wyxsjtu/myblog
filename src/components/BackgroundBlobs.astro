---
// 5 个动态光晕，分散在视口四角与中心，独立缓慢漂移
// 仅 transform 参与动画 → 走 GPU
// prefers-reduced-motion: reduce 时停止动画
---

<div class="bg-blobs" aria-hidden="true">
  <span class="blob blob-1"></span>
  <span class="blob blob-2"></span>
  <span class="blob blob-3"></span>
  <span class="blob blob-4"></span>
  <span class="blob blob-5"></span>
</div>

<style>
  .bg-blobs {
    position: fixed;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: -1;
    transform: translateZ(0);
  }
  .blob {
    position: absolute;
    border-radius: 50%;
    /* 更大的模糊半径，让光团边缘更柔，不容易抢眼 */
    filter: blur(85px);
    will-change: transform;
    transform: translate3d(0, 0, 0);
  }

  /* ---- 5 个光团：位置 + 颜色 + 大小 ---- */
  .blob-1 {
    top: -12%;
    left: -8%;
    width: 36vw;
    height: 36vw;
    max-width: 580px;
    max-height: 580px;
    background: var(--blob-blue);
    animation: drift-1 60s ease-in-out infinite;
  }
  .blob-2 {
    top: -8%;
    right: -10%;
    width: 32vw;
    height: 32vw;
    max-width: 520px;
    max-height: 520px;
    background: var(--blob-purple);
    animation: drift-2 78s ease-in-out infinite;
    animation-delay: -12s;
  }
  .blob-3 {
    top: 38%;
    right: -12%;
    width: 30vw;
    height: 30vw;
    max-width: 480px;
    max-height: 480px;
    background: var(--blob-teal);
    animation: drift-3 90s ease-in-out infinite;
    animation-delay: -25s;
  }
  .blob-4 {
    bottom: -10%;
    left: -8%;
    width: 34vw;
    height: 34vw;
    max-width: 560px;
    max-height: 560px;
    background: var(--blob-pink);
    animation: drift-4 70s ease-in-out infinite;
    animation-delay: -8s;
  }
  .blob-5 {
    top: 32%;
    left: 28%;
    width: 26vw;
    height: 26vw;
    max-width: 440px;
    max-height: 440px;
    background: var(--blob-amber);
    animation: drift-5 100s ease-in-out infinite;
    animation-delay: -40s;
  }

  /* ---- 漂移轨迹：位移幅度比之前减半，让运动更细腻 ---- */
  @keyframes drift-1 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    33%      { transform: translate3d(8vw, 12vh, 0) scale(1.08); }
    66%      { transform: translate3d(-3vw, 24vh, 0) scale(0.95); }
  }
  @keyframes drift-2 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    25%      { transform: translate3d(-10vw, 9vh, 0) scale(1.1); }
    50%      { transform: translate3d(-4vw, 22vh, 0) scale(0.92); }
    75%      { transform: translate3d(4vw, 14vh, 0) scale(1.05); }
  }
  @keyframes drift-3 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    33%      { transform: translate3d(-12vw, -8vh, 0) scale(1.06); }
    66%      { transform: translate3d(-6vw, 11vh, 0) scale(0.96); }
  }
  @keyframes drift-4 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    25%      { transform: translate3d(10vw, -14vh, 0) scale(0.96); }
    50%      { transform: translate3d(16vw, -6vh, 0) scale(1.08); }
    75%      { transform: translate3d(4vw, -10vh, 0) scale(1.02); }
  }
  @keyframes drift-5 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    20%      { transform: translate3d(-7vw, 5vh, 0) scale(1.1); }
    50%      { transform: translate3d(10vw, 10vh, 0) scale(0.92); }
    80%      { transform: translate3d(5vw, -5vh, 0) scale(1.04); }
  }

  /* 减动画偏好：停止运动，但保留静态光晕 */
  @media (prefers-reduced-motion: reduce) {
    .blob {
      animation: none !important;
    }
  }
</style>
