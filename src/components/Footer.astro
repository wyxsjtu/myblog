---
import { SITE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="footer-left muted">
      &copy; {year} {SITE.author}
      {SITE.school && <span class="sep"> · </span>}
      {SITE.school && <span class="affil">{SITE.school}</span>}
    </p>
    <p class="footer-right subtle">
      Built with <a href="https://astro.build/">Astro</a> on Cloudflare Pages
    </p>
  </div>
</footer>

<style>
  .site-footer {
    /* 固定在视口底部，始终可见 */
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 5;
    border-top: 1px solid var(--border);
    background: var(--bg-elevated-translucent);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    backdrop-filter: saturate(180%) blur(12px);
    padding: 0.75rem 0;
    font-size: 0.86rem;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .footer-inner p { margin: 0; }
  .footer-inner a { color: inherit; }
  .footer-inner a:hover { color: var(--accent); }

  .sep { color: var(--text-subtle); }
  .affil { color: var(--text-muted); }

  /* 窄屏只保留左侧版权信息 */
  @media (max-width: 640px) {
    .footer-right { display: none; }
    .footer-left { font-size: 0.82rem; }
  }
</style>
