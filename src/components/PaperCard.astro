---
import CCFBadge from './CCFBadge.astro';

interface Links {
  pdf?: string;
  code?: string;
  slides?: string;
  video?: string;
  arxiv?: string;
  doi?: string;
  bibtex?: string;
  project?: string;
}

interface Props {
  title: string;
  authors: string;
  venue: string;
  year: number;
  ccf: 'A' | 'B' | 'C' | 'SCI' | 'None';
  type: 'conference' | 'journal' | 'preprint' | 'patent' | 'other';
  abstract?: string;
  links?: Links;
  featured?: boolean;
}

const {
  title,
  authors,
  venue,
  year,
  ccf,
  type,
  abstract,
  links = {},
  featured = false,
} = Astro.props;

const typeLabels: Record<Props['type'], string> = {
  conference: '会议',
  journal: '期刊',
  preprint: '预印本',
  patent: '专利',
  other: '其他',
};

// 链接按统一格式渲染
const linkOrder: Array<[keyof Links, string]> = [
  ['pdf', 'PDF'],
  ['arxiv', 'arXiv'],
  ['doi', 'DOI'],
  ['code', 'Code'],
  ['project', '项目主页'],
  ['slides', 'Slides'],
  ['video', 'Video'],
  ['bibtex', 'BibTeX'],
];
const visibleLinks = linkOrder.filter(([k]) => !!links[k]);
---

<article class:list={['paper-card', { featured }]}>
  <div class="paper-head">
    <h3 class="paper-title">{title}</h3>
    {featured && <span class="featured-badge">代表作</span>}
  </div>

  <p class="paper-authors" set:html={authors}></p>

  <div class="paper-meta">
    <span class="venue">{venue}</span>
    <span class="year subtle">·  {year}</span>
    <span class="type subtle">·  {typeLabels[type]}</span>
    <CCFBadge level={ccf} />
  </div>

  {abstract && <p class="paper-abstract muted">{abstract}</p>}

  {visibleLinks.length > 0 && (
    <div class="paper-links">
      {visibleLinks.map(([k, label]) => (
        <a
          href={links[k]}
          target="_blank"
          rel="noopener"
          class="paper-link"
          download={k === 'pdf' || k === 'slides' || k === 'bibtex' ? true : undefined}
        >
          {label === 'PDF' && (
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
          )}
          {label === 'Code' && (
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/>
              <polyline points="8 6 2 12 8 18"/>
            </svg>
          )}
          {label !== 'PDF' && label !== 'Code' && (
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          )}
          <span>{label}</span>
        </a>
      ))}
    </div>
  )}
</article>

<style>
  .paper-card {
    padding: 1.25rem 1.4rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg-elevated-translucent);
    -webkit-backdrop-filter: saturate(180%) blur(8px);
    backdrop-filter: saturate(180%) blur(8px);
    transition: border-color var(--transition), transform var(--transition);
  }
  .paper-card:hover {
    border-color: var(--text-subtle);
  }
  .paper-card.featured {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }

  .paper-head {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
  }
  .paper-title {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.4;
    font-weight: 600;
    flex: 1 1 auto;
  }
  .featured-badge {
    flex: 0 0 auto;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    line-height: 1.4;
  }

  .paper-authors {
    margin: 0 0 0.5rem;
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.55;
  }
  /* author 字符串里 **本人** 会渲染为加粗，需要自定义样式 */
  .paper-authors :global(strong) {
    color: var(--text);
    font-weight: 700;
  }

  .paper-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    margin-bottom: 0.6rem;
  }
  .venue { font-weight: 500; font-style: italic; }

  .paper-abstract {
    margin: 0.5rem 0 0.8rem;
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .paper-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.4rem;
  }
  .paper-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.25rem 0.6rem;
    font-size: 0.8rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition), border-color var(--transition);
  }
  .paper-link:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }
</style>
