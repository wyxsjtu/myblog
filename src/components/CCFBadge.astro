---
interface Props {
  level: 'A' | 'B' | 'C' | 'SCI' | 'None';
}
const { level } = Astro.props;

const labels: Record<Props['level'], string> = {
  A: 'CCF-A',
  B: 'CCF-B',
  C: 'CCF-C',
  SCI: 'SCI',
  None: '',
};

const text = labels[level];
---

{text && (
  <span class:list={['ccf-badge', `level-${level.toLowerCase()}`]} title={`等级：${text}`}>
    {text}
  </span>
)}

<style>
  .ccf-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.1rem 0.5rem;
    font-size: 0.72rem;
    font-weight: 600;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
    border-radius: 4px;
    border: 1px solid currentColor;
    line-height: 1.4;
  }
  /* CCF-A: 红 */
  .level-a {
    color: #dc2626;
    background: rgb(220 38 38 / 0.08);
  }
  :root[data-theme='dark'] .level-a {
    color: #f87171;
    background: rgb(248 113 113 / 0.12);
  }
  /* CCF-B: 橙 */
  .level-b {
    color: #d97706;
    background: rgb(217 119 6 / 0.08);
  }
  :root[data-theme='dark'] .level-b {
    color: #fbbf24;
    background: rgb(251 191 36 / 0.12);
  }
  /* CCF-C: 蓝 */
  .level-c {
    color: #2563eb;
    background: rgb(37 99 235 / 0.08);
  }
  :root[data-theme='dark'] .level-c {
    color: #60a5fa;
    background: rgb(96 165 250 / 0.12);
  }
  /* SCI: 绿 */
  .level-sci {
    color: #059669;
    background: rgb(5 150 105 / 0.08);
  }
  :root[data-theme='dark'] .level-sci {
    color: #34d399;
    background: rgb(52 211 153 / 0.12);
  }
</style>
