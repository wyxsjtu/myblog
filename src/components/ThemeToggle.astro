---
// 主题切换按钮：在 light / dark 间切换，持久化到 localStorage
---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="切换主题"
  title="切换主题"
>
  <svg class="icon icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path><path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path><path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
  <svg class="icon icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text);
    width: 38px;
    height: 38px;
    border-radius: var(--radius);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition), border-color var(--transition);
  }
  .theme-toggle:hover {
    background: var(--bg-elevated);
    border-color: var(--text-subtle);
  }
  .icon { display: none; }
  :root[data-theme='dark'] .icon-sun { display: block; }
  :root:not([data-theme='dark']) .icon-moon { display: block; }
</style>

<script is:inline>
  // 该脚本在 <BaseLayout> 的 <head> 中也内联了一个早期版本以避免 FOUC
  const btn = document.getElementById('theme-toggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const current = root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
      const next = current === 'dark' ? 'light' : 'dark';
      root.classList.add('no-transition');
      if (next === 'dark') root.setAttribute('data-theme', 'dark');
      else root.removeAttribute('data-theme');
      try { localStorage.setItem('theme', next); } catch {}
      // 强制下一帧再恢复 transition
      requestAnimationFrame(() => {
        requestAnimationFrame(() => root.classList.remove('no-transition'));
      });
    });
  }
</script>
