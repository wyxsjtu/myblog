---
// 搜索按钮 + 模态框：客户端获取 /search-index.json，做 includes 匹配
---

<button
  id="search-trigger"
  class="search-trigger"
  type="button"
  aria-label="搜索"
  title="搜索 (按 / 或 Cmd/Ctrl+K)"
>
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="7"></circle>
    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
  </svg>
  <span class="kbd">⌘K</span>
</button>

<dialog id="search-dialog" class="search-dialog" aria-label="搜索">
  <div class="search-panel">
    <div class="search-input-wrap">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        id="search-input"
        type="search"
        autocomplete="off"
        spellcheck="false"
        placeholder="搜索文章、研究成果..."
        aria-label="搜索"
      />
      <button id="search-close" class="close-btn" type="button" aria-label="关闭">
        <span class="kbd small">Esc</span>
      </button>
    </div>

    <div id="search-results" class="search-results" role="listbox">
      <div class="search-hint muted">输入关键词搜索文章标题、内容、标签或研究论文。</div>
    </div>

    <div class="search-footer subtle">
      <span><kbd>↑</kbd><kbd>↓</kbd> 选择</span>
      <span><kbd>Enter</kbd> 打开</span>
      <span><kbd>Esc</kbd> 关闭</span>
    </div>
  </div>
</dialog>

<style>
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.65rem;
    height: 38px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-elevated-translucent);
    color: var(--text-muted);
    font-size: 0.85rem;
    cursor: pointer;
    transition: border-color var(--transition), color var(--transition);
  }
  .search-trigger:hover {
    color: var(--text);
    border-color: var(--text-subtle);
  }
  .kbd {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.05rem 0.35rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    color: var(--text-subtle);
  }
  .kbd.small { font-size: 0.65rem; }

  /* dialog 重置 */
  .search-dialog {
    padding: 0;
    border: 0;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    /* 居中 */
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    margin: 0;
  }
  .search-dialog::backdrop {
    background: rgb(0 0 0 / 0.45);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .search-dialog[open] {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: 12vh;
  }

  .search-panel {
    width: min(640px, calc(100vw - 2rem));
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: 0 12px 40px rgb(0 0 0 / 0.18);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 75vh;
  }

  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--border);
  }
  .search-icon {
    color: var(--text-subtle);
    flex: 0 0 auto;
  }
  #search-input {
    flex: 1 1 auto;
    border: 0;
    background: transparent;
    color: var(--text);
    font-size: 1rem;
    font-family: var(--font-sans);
    outline: none;
    padding: 0.2rem 0;
    min-width: 0;
  }
  #search-input::placeholder { color: var(--text-subtle); }

  .close-btn {
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 0;
  }

  .search-results {
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 0.5rem 0;
  }
  .search-hint, .search-empty {
    padding: 1.5rem 1rem;
    text-align: center;
    font-size: 0.9rem;
  }

  .result-group {
    padding: 0.4rem 1rem 0.2rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-subtle);
    font-weight: 600;
  }

  .result-item {
    display: block;
    padding: 0.6rem 1rem;
    border-left: 2px solid transparent;
    color: var(--text);
    text-decoration: none;
    cursor: pointer;
    transition: background var(--transition), border-color var(--transition);
  }
  .result-item:hover,
  .result-item.active {
    background: var(--bg-code);
    border-left-color: var(--accent);
    text-decoration: none;
  }
  .result-title {
    font-weight: 500;
    font-size: 0.95rem;
    margin: 0 0 0.15rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .result-type-badge {
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.05rem 0.4rem;
    border-radius: 3px;
    line-height: 1.5;
  }
  .result-type-badge.post {
    color: var(--accent);
    background: var(--tag-bg);
  }
  .result-type-badge.paper {
    color: #c026d3;
    background: rgb(192 38 211 / 0.10);
  }
  :root[data-theme='dark'] .result-type-badge.paper {
    color: #e879f9;
    background: rgb(232 121 249 / 0.12);
  }
  .result-excerpt {
    margin: 0;
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.5;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .result-meta {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.72rem;
    color: var(--text-subtle);
    font-family: var(--font-mono);
  }
  .result-item :global(mark) {
    background: rgb(250 204 21 / 0.35);
    color: inherit;
    padding: 0 0.1rem;
    border-radius: 2px;
  }
  :root[data-theme='dark'] .result-item :global(mark) {
    background: rgb(250 204 21 / 0.25);
  }

  .search-footer {
    display: flex;
    gap: 1rem;
    padding: 0.55rem 1rem;
    border-top: 1px solid var(--border);
    font-size: 0.72rem;
    flex-wrap: wrap;
  }
  .search-footer kbd {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0 0.3rem;
    margin-right: 0.2rem;
    border: 1px solid var(--border);
    border-radius: 3px;
  }

  @media (max-width: 540px) {
    .search-trigger .kbd { display: none; }
    .search-dialog[open] { padding-top: 6vh; }
  }
</style>

<script>
  interface SearchDoc {
    id: string;
    type: 'post' | 'paper';
    title: string;
    excerpt: string;
    url: string;
    haystack: string;
    meta: string;
  }

  const trigger = document.getElementById('search-trigger') as HTMLButtonElement | null;
  const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
  const input = document.getElementById('search-input') as HTMLInputElement | null;
  const results = document.getElementById('search-results') as HTMLDivElement | null;
  const closeBtn = document.getElementById('search-close') as HTMLButtonElement | null;

  if (trigger && dialog && input && results && closeBtn) {
    let docs: SearchDoc[] | null = null;
    let loading = false;
    let activeIndex = 0;
    let currentResults: SearchDoc[] = [];

    const loadIndex = async () => {
      if (docs || loading) return;
      loading = true;
      try {
        const res = await fetch('/search-index.json');
        docs = await res.json();
      } catch (e) {
        console.error('search index fetch failed', e);
        docs = [];
      } finally {
        loading = false;
      }
    };

    const escapeHtml = (s: string) =>
      s.replace(/[&<>"']/g, (c) => (
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' } as Record<string, string>)[c]!
      ));

    const escapeRe = (s: string) => s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

    const highlight = (text: string, query: string) => {
      const escaped = escapeHtml(text);
      if (!query) return escaped;
      const re = new RegExp(`(${escapeRe(query)})`, 'gi');
      return escaped.replace(re, '<mark>$1</mark>');
    };

    const search = (q: string) => {
      if (!docs) return [] as SearchDoc[];
      const query = q.trim().toLowerCase();
      if (!query) return [];
      const tokens = query.split(/\s+/).filter(Boolean);
      const scored: Array<{ doc: SearchDoc; score: number }> = [];
      for (const doc of docs) {
        let score = 0;
        let matched = true;
        for (const tok of tokens) {
          const inTitle = doc.title.toLowerCase().includes(tok);
          const inHay = doc.haystack.includes(tok);
          if (!inTitle && !inHay) {
            matched = false;
            break;
          }
          if (inTitle) score += 10;
          if (inHay) score += 1;
        }
        if (matched) scored.push({ doc, score });
      }
      scored.sort((a, b) => b.score - a.score);
      return scored.slice(0, 12).map((s) => s.doc);
    };

    const render = (q: string) => {
      const found = search(q);
      currentResults = found;
      activeIndex = 0;

      if (!q.trim()) {
        results.innerHTML = '<div class="search-hint muted">输入关键词搜索文章标题、内容、标签或研究论文。</div>';
        return;
      }
      if (found.length === 0) {
        results.innerHTML = `<div class="search-empty muted">未找到匹配「${escapeHtml(q)}」的内容。</div>`;
        return;
      }

      const posts = found.filter((d) => d.type === 'post');
      const papers = found.filter((d) => d.type === 'paper');

      const renderItem = (doc: SearchDoc, idx: number) => `
        <a class="result-item${idx === 0 ? ' active' : ''}" href="${doc.url}" data-idx="${idx}" role="option">
          <div class="result-title">
            <span class="result-type-badge ${doc.type}">${doc.type === 'post' ? '文章' : '研究'}</span>
            <span>${highlight(doc.title, q)}</span>
          </div>
          <p class="result-excerpt">${highlight(doc.excerpt, q)}</p>
          <span class="result-meta">${escapeHtml(doc.meta)}</span>
        </a>
      `;

      let html = '';
      let idx = 0;
      if (posts.length > 0) {
        html += `<div class="result-group">文章</div>`;
        for (const d of posts) html += renderItem(d, idx++);
      }
      if (papers.length > 0) {
        html += `<div class="result-group">研究成果</div>`;
        for (const d of papers) html += renderItem(d, idx++);
      }
      results.innerHTML = html;
    };

    const setActive = (newIdx: number) => {
      const items = results.querySelectorAll<HTMLElement>('.result-item');
      if (items.length === 0) return;
      activeIndex = (newIdx + items.length) % items.length;
      items.forEach((el, i) => el.classList.toggle('active', i === activeIndex));
      const active = items[activeIndex];
      if (active) active.scrollIntoView({ block: 'nearest' });
    };

    const open = async () => {
      if (typeof dialog.showModal === 'function') dialog.showModal();
      else dialog.setAttribute('open', '');
      await loadIndex();
      input.value = '';
      render('');
      setTimeout(() => input.focus(), 30);
    };

    const close = () => {
      if (typeof dialog.close === 'function') dialog.close();
      else dialog.removeAttribute('open');
    };

    trigger.addEventListener('click', open);
    closeBtn.addEventListener('click', close);

    // 点击 backdrop 关闭
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) close();
    });

    // 输入：debounce
    let debounceTimer: ReturnType<typeof setTimeout> | null = null;
    input.addEventListener('input', () => {
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => render(input.value), 120);
    });

    // 键盘导航
    input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(activeIndex + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(activeIndex - 1);
      } else if (e.key === 'Enter') {
        e.preventDefault();
        const items = results.querySelectorAll<HTMLAnchorElement>('.result-item');
        const target = items[activeIndex];
        if (target) {
          window.location.href = target.href;
        }
      }
    });

    // 全局快捷键：/ 或 Cmd/Ctrl+K 打开
    document.addEventListener('keydown', (e) => {
      const target = e.target as HTMLElement | null;
      const inField =
        target &&
        (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.isContentEditable);
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        open();
      } else if (e.key === '/' && !inField && !dialog.hasAttribute('open')) {
        e.preventDefault();
        open();
      }
    });
  }
</script>
