---
interface Props {
  tags: string[];
}
const { tags } = Astro.props;
// 见 src/utils/posts.ts 的 slugifyTag：不要预编码，让磁盘和路由匹配
const slugify = (s: string) => s.toLowerCase().trim().replace(/\s+/g, '-');
---

{tags.length > 0 && (
  <span class="tag-list">
    {tags.map((t) => (
      <a href={`/tags/${slugify(t)}/`} class="tag">#{t}</a>
    ))}
  </span>
)}

<style>
  .tag-list { display: inline-flex; flex-wrap: wrap; gap: 0.35rem; }
</style>
