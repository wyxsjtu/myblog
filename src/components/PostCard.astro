---
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';

interface Props {
  href: string;
  title: string;
  description?: string;
  pubDate: Date;
  category?: string;
  tags?: string[];
}

const { href, title, description, pubDate, category, tags = [] } = Astro.props;
---

<article class="post-card">
  <a href={href} class="post-card-link">
    <h2 class="post-title">{title}</h2>
    {description && <p class="post-desc muted">{description}</p>}
  </a>
  <div class="post-meta">
    {category && (
      <span class:list={['post-category', `cat-${category}`]}>{category}</span>
    )}
    <FormattedDate date={pubDate} />
    {tags.length > 0 && <span class="dot">·</span>}
    <TagList tags={tags} />
  </div>
</article>

<style>
  .post-card {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }
  .post-card:last-child { border-bottom: 0; }
  .post-card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .post-card-link:hover { text-decoration: none; }
  .post-card-link:hover .post-title { color: var(--accent); }
  .post-title {
    font-size: 1.25rem;
    margin: 0 0 0.4rem;
    font-weight: 600;
    transition: color var(--transition);
  }
  .post-desc {
    margin: 0 0 0.6rem;
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--text-subtle);
    font-size: 0.85rem;
  }
  .dot { color: var(--text-subtle); }

  /* 分类徽标：极简风，不同分类不同色相 */
  .post-category {
    display: inline-flex;
    align-items: center;
    padding: 0.1rem 0.5rem;
    font-size: 0.72rem;
    font-weight: 500;
    border-radius: 4px;
    border: 1px solid currentColor;
    line-height: 1.5;
    letter-spacing: 0.02em;
  }
  /* 默认色：跟随主题主色 */
  .post-category {
    color: var(--accent);
    background: var(--tag-bg);
  }
  /* 通过 cat-* 给各分类配独立色相，命中不到的回退到默认色 */
  .cat-技术 {
    color: #2563eb;
    background: rgb(37 99 235 / 0.10);
  }
  :root[data-theme='dark'] .cat-技术 {
    color: #60a5fa;
    background: rgb(96 165 250 / 0.14);
  }
  .cat-生活 {
    color: #db2777;
    background: rgb(219 39 119 / 0.10);
  }
  :root[data-theme='dark'] .cat-生活 {
    color: #f472b6;
    background: rgb(244 114 182 / 0.14);
  }
  .cat-思考 {
    color: #d97706;
    background: rgb(217 119 6 / 0.10);
  }
  :root[data-theme='dark'] .cat-思考 {
    color: #fbbf24;
    background: rgb(251 191 36 / 0.14);
  }
</style>
