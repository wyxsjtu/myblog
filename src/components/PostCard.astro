---
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';

interface Props {
  href: string;
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
}

const { href, title, description, pubDate, tags = [] } = Astro.props;
---

<article class="post-card">
  <a href={href} class="post-card-link">
    <h2 class="post-title">{title}</h2>
    {description && <p class="post-desc muted">{description}</p>}
  </a>
  <div class="post-meta">
    <FormattedDate date={pubDate} />
    {tags.length > 0 && <span class="dot">·</span>}
    <TagList tags={tags} />
  </div>
</article>

<style>
  .post-card {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }
  .post-card:last-child { border-bottom: 0; }
  .post-card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .post-card-link:hover { text-decoration: none; }
  .post-card-link:hover .post-title { color: var(--accent); }
  .post-title {
    font-size: 1.25rem;
    margin: 0 0 0.4rem;
    font-weight: 600;
    transition: color var(--transition);
  }
  .post-desc {
    margin: 0 0 0.6rem;
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--text-subtle);
    font-size: 0.85rem;
  }
  .dot { color: var(--text-subtle); }
</style>
